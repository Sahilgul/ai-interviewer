# URL of the FastAPI token server (the `backend/` service).
# - In dev, Vite proxies /api/* to this URL.
# - In prod builds, the app calls this URL directly (no proxy).
# Leave empty to call the same origin the frontend is served from.
VITE_BACKEND_URL=http://localhost:8000

# Path on the backend that mints the LiveKit token + room metadata.
VITE_CONNECTION_DETAILS_PATH=/api/connection-details

# Vite dev server port.
VITE_DEV_PORT=5173
